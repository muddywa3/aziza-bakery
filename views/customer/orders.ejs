<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d4af37',
                        gold: '#d4af37'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50">
    <%- include('../partials/navbar') %>
    
    <div class="pt-24 pb-12">
        <div class="container mx-auto px-6 lg:px-12">
            <div class="max-w-4xl mx-auto">
                <h1 class="text-3xl font-bold text-gray-900 mb-8">My Orders</h1>
                
                <% if (orders && orders.length > 0) { %>
                    <div class="space-y-6">
                        <% orders.forEach(order => { %>
                            <div class="bg-white rounded-lg shadow-md p-6">
                                <div class="flex justify-between items-start mb-4">
                                    <div>
                                        <h3 class="text-lg font-semibold text-gray-900">Order #<%= order.orderNumber %></h3>
                                        <p class="text-sm text-gray-600">Placed on <%= new Date(order.createdAt).toLocaleDateString() %></p>
                                    </div>
                                    <div class="text-right">
                                        <span class="inline-block px-3 py-1 rounded-full text-sm font-medium
                                            <% if (order.status === 'completed') { %>bg-green-100 text-green-800
                                            <% } else if (order.status === 'processing') { %>bg-blue-100 text-blue-800
                                            <% } else if (order.status === 'cancelled') { %>bg-red-100 text-red-800
                                            <% } else { %>bg-yellow-100 text-yellow-800<% } %>">
                                            <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                                        </span>
                                        <p class="text-lg font-semibold text-gray-900 mt-1">$<%= order.totals.total.toFixed(2) %></p>
                                    </div>
                                </div>
                                
                                <div class="border-t pt-4">
                                    <h4 class="font-medium text-gray-900 mb-2">Items:</h4>
                                    <div class="space-y-2">
                                        <% order.items.forEach(item => { %>
                                            <div class="flex justify-between text-sm">
                                                <span><%= item.name %> × <%= item.quantity %></span>
                                                <span>$<%= (item.price * item.quantity).toFixed(2) %></span>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                                
                                <% if (order.trackingCode) { %>
                                    <div class="border-t pt-4 mt-4">
                                        <p class="text-sm text-gray-600">
                                            Tracking Code: <span class="font-mono font-medium"><%= order.trackingCode %></span>
                                        </p>
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-12">
                        <div class="text-gray-400 text-6xl mb-4">🛒</div>
                        <h3 class="text-xl font-medium text-gray-900 mb-2">No orders yet</h3>
                        <p class="text-gray-600 mb-6">You haven't placed any orders with us yet.</p>
                        <a href="/menu" class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors">
                            Browse Menu
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>