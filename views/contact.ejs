<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact Us - Aziza Bakery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
      body { 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f8f0e3; 
        min-height: 100vh;
      }
      
      .contact-header {
        background: linear-gradient(135deg, #d35400 0%, #e67e22 100%);
        color: white;
        padding: 80px 20px;
        text-align: center;
        margin-bottom: 50px;
      }
      
      .contact-header h1 {
        font-size: 3rem;
        font-weight: bold;
        margin-bottom: 15px;
      }
      
      .contact-header p {
        font-size: 1.2rem;
        opacity: 0.95;
      }
      
      .contact-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 20px 80px;
      }
      
      .contact-card {
        background: white;
        border-radius: 20px;
        padding: 50px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      }
      
      .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
      }
      
      .form-control, .form-control:focus {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 12px 20px;
        font-size: 1rem;
      }
      
      .form-control:focus {
        border-color: #d35400;
        box-shadow: 0 0 0 0.2rem rgba(211, 84, 0, 0.15);
      }
      
      textarea.form-control {
        min-height: 150px;
        resize: vertical;
      }
      
      .submit-btn {
        background: #d35400;
        color: white;
        border: none;
        padding: 15px 50px;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 20px;
      }
      
      .submit-btn:hover {
        background: #e67e22;
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(211, 84, 0, 0.3);
      }
      
      .contact-info {
        margin-top: 50px;
        text-align: center;
        padding: 30px;
        background: #fff3e0;
        border-radius: 15px;
      }
      
      .contact-info h3 {
        color: #d35400;
        margin-bottom: 20px;
      }
      
      .contact-info p {
        margin: 10px 0;
        color: #666;
        font-size: 1.1rem;
      }
      
      .back-link {
        display: inline-block;
        margin: 30px 0;
        color: #d35400;
        text-decoration: none;
        font-weight: bold;
        transition: all 0.3s ease;
      }
      
      .back-link:hover {
        color: #e67e22;
        transform: translateX(-5px);
      }
      
      .success-message {
        background: #d4edda;
        color: #155724;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        border: 1px solid #c3e6cb;
      }
    </style>
</head>
<body>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold fs-4" href="/">🍰 Aziza Bakery</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/gallery">Gallery</a></li>
        <li class="nav-item"><a class="nav-link" href="/menu">Menu</a></li>
        <li class="nav-item"><a class="nav-link active" href="/contact">Contact</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Header -->
<div class="contact-header">
  <h1>Get In Touch</h1>
  <p>We'd love to hear from you!</p>
</div>

<!-- Contact Form -->
<div class="contact-container">
  <a href="/" class="back-link">← Back to Home</a>
  
  <div class="contact-card">
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="success-message">
        ✓ Thank you! Your message has been sent successfully. We'll get back to you soon!
      </div>
    <% } %>
    
    <form action="/contact" method="POST">
      <div class="mb-4">
        <label for="name" class="form-label">Your Name</label>
        <input 
          type="text" 
          class="form-control" 
          id="name" 
          name="name" 
          placeholder="Enter your full name"
          required
        >
      </div>
      
      <div class="mb-4">
        <label for="email" class="form-label">Email Address</label>
        <input 
          type="email" 
          class="form-control" 
          id="email" 
          name="email" 
          placeholder="your.email@example.com"
          required
        >
      </div>
      
      <div class="mb-4">
        <label for="message" class="form-label">Message</label>
        <textarea 
          class="form-control" 
          id="message" 
          name="message" 
          placeholder="Tell us what's on your mind..."
          required
        ></textarea>
      </div>
      
      <button type="submit" class="submit-btn">Send Message</button>
    </form>
  </div>
  
  <div class="contact-info">
    <h3>Contact Information</h3>
    <p>📍 123 Bakery Street, Sweet City</p>
    <p>📞 +1 (555) 123-4567</p>
    <p>📧 hello@azizabakery.com</p>
    <p>🕒 Mon-Sat: 7:00 AM - 8:00 PM</p>
  </div>
</div>

<!-- Footer -->
<footer class="bg-dark text-white text-center p-4 mt-5">
  <div class="container">
    <p class="mb-2">© 2026 Aziza Bakery | Made with ❤️</p>
    <p class="mb-0 small">📍 Location | 📞 Contact | 📧 Email</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
