<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
      .sidebar-link.active { background: rgba(211, 84, 0, 0.1); border-left: 4px solid #d35400; }
      .image-option { cursor: pointer; transition: all 0.3s; }
      .image-option.selected { border-color: #d35400; box-shadow: 0 0 0 3px rgba(211, 84, 0, 0.2); }
    </style>
</head>
<body class="bg-gray-50">
    
    <div class="flex h-screen overflow-hidden">
        <%- include('../../partials/sidebar', { role: role }) %>
        
        <div class="flex-1 flex flex-col overflow-hidden">
            <%- include('../../partials/topnav', { username: username, title: title, role: role }) %>
            
            <main class="flex-1 overflow-y-auto p-6">
                <div class="max-w-3xl mx-auto">
                    <div class="mb-6">
                        <a href="/admin/products" class="text-gray-600 hover:text-primary transition inline-flex items-center">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                            </svg>
                            Back to Products
                        </a>
                    </div>
                    
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6">Edit Product</h2>
                        
                        <form action="/admin/products/<%= product._id %>/edit" method="POST" class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Product Name *</label>
                                <input type="text" name="name" value="<%= product.name %>" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="e.g., Chocolate Cake">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Description *</label>
                                <textarea name="description" required rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Describe your product..."><%= product.description %></textarea>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Price ($) *</label>
                                    <input type="number" name="price" value="<%= product.price %>" step="0.01" min="0" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="0.00">
                                </div>
                                
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Category *</label>
                                    <select name="category" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
                                        <option value="cakes" <%= product.category === 'cakes' ? 'selected' : '' %>>Cakes</option>
                                        <option value="pastries" <%= product.category === 'pastries' ? 'selected' : '' %>>Pastries</option>
                                        <option value="breads" <%= product.category === 'breads' ? 'selected' : '' %>>Breads</option>
                                        <option value="cookies" <%= product.category === 'cookies' ? 'selected' : '' %>>Cookies</option>
                                        <option value="special" <%= product.category === 'special' ? 'selected' : '' %>>Special</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Select Image *</label>
                                <input type="hidden" name="image" id="selectedImage" value="<%= product.image %>" required>
                                <div class="grid grid-cols-4 gap-4 max-h-96 overflow-y-auto p-4 border border-gray-200 rounded-lg">
                                    <% images.forEach(image => { %>
                                        <div class="image-option border-2 <%= image === product.image ? 'border-primary selected' : 'border-gray-200' %> rounded-lg overflow-hidden hover:border-primary" onclick="selectImage('<%= image %>', this)">
                                            <img src="/images/<%= image %>" alt="<%= image %>" class="w-full h-24 object-cover">
                                            <p class="text-xs text-center p-2 truncate"><%= image %></p>
                                        </div>
                                    <% }) %>
                                </div>
                                <p class="text-sm text-gray-500 mt-2">Click on an image to select it</p>
                            </div>
                            
                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <input type="checkbox" name="featured" id="featured" <%= product.featured ? 'checked' : '' %> class="w-4 h-4 text-primary border-gray-300 rounded focus:ring-primary">
                                    <label for="featured" class="ml-2 text-sm text-gray-700">Mark as featured product</label>
                                </div>
                                <div class="flex items-center">
                                    <input type="checkbox" name="isAvailable" id="isAvailable" <%= product.isAvailable ? 'checked' : '' %> class="w-4 h-4 text-primary border-gray-300 rounded focus:ring-primary">
                                    <label for="isAvailable" class="ml-2 text-sm text-gray-700">Product is available</label>
                                </div>
                            </div>
                            
                            <div class="flex gap-4 pt-4">
                                <button type="submit" class="flex-1 px-6 py-3 bg-primary hover:bg-secondary text-white rounded-lg transition font-medium">
                                    Update Product
                                </button>
                                <a href="/admin/products" class="flex-1 px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg transition font-medium text-center">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </main>
        </div>
    </div>
    
    <script>
        function selectImage(filename, element) {
            document.querySelectorAll('.image-option').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            document.getElementById('selectedImage').value = filename;
        }
        
        const currentPath = window.location.pathname;
        document.querySelectorAll('.sidebar-link').forEach(link => {
            if (link.getAttribute('href') === '/admin/products') {
                link.classList.add('active');
            }
        });
    </script>
</body>
</html>
