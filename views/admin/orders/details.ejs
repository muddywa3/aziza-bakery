<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
      .sidebar-link.active { background: rgba(211, 84, 0, 0.1); border-left: 4px solid #d35400; }
    </style>
</head>
<body class="bg-gray-50">
    
    <div class="flex h-screen overflow-hidden">
        <%- include('../../partials/sidebar', { role: role }) %>
        
        <div class="flex-1 flex flex-col overflow-hidden">
            <%- include('../../partials/topnav', { username: username, title: title, role: role }) %>
            
            <main class="flex-1 overflow-y-auto p-6">
                <div class="max-w-4xl mx-auto">
                    
                    <!-- Back Button -->
                    <div class="mb-6">
                        <a href="/admin/orders" class="text-gray-600 hover:text-primary transition inline-flex items-center">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                            </svg>
                            Back to Orders
                        </a>
                    </div>

                    <!-- Order Header -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 mb-6">
                        <div class="flex justify-between items-start">
                            <div>
                                <h2 class="font-display text-3xl font-bold text-gray-900 mb-2">Order #<%= order.orderNumber %></h2>
                                <p class="text-gray-600">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-US', { 
                                    weekday: 'long', 
                                    year: 'numeric', 
                                    month: 'long', 
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                }) %></p>
                            </div>
                            <div class="text-right">
                                <div class="text-3xl font-bold text-primary mb-2">$<%= order.totals.total.toFixed(2) %></div>
                                <select onchange="updateOrderStatus('<%= order._id %>', this.value)" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
                                    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                    <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>Preparing</option>
                                    <option value="ready" <%= order.status === 'ready' ? 'selected' : '' %>>Ready</option>
                                    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
                                    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        
                        <!-- Customer Information -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                            <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Customer Information</h3>
                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                    </svg>
                                    <span class="font-medium"><%= order.customer.name %></span>
                                </div>
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                    </svg>
                                    <span><%= order.customer.email %></span>
                                </div>
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                    </svg>
                                    <span><%= order.customer.phone %></span>
                                </div>
                            </div>
                        </div>

                        <!-- Delivery Information -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                            <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Delivery Information</h3>
                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0V6a2 2 0 012-2h4a2 2 0 012 2v1m-6 0h8m-8 0H6a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-2"/>
                                    </svg>
                                    <span class="capitalize font-medium"><%= order.delivery.type %></span>
                                </div>
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <span><%= new Date(order.delivery.scheduledFor).toLocaleDateString('en-US', { 
                                        weekday: 'long', 
                                        year: 'numeric', 
                                        month: 'long', 
                                        day: 'numeric',
                                        hour: '2-digit',
                                        minute: '2-digit'
                                    }) %></span>
                                </div>
                                <% if (order.delivery.type === 'delivery' && order.delivery.address) { %>
                                    <div class="flex items-start">
                                        <svg class="w-5 h-5 text-primary mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        </svg>
                                        <div>
                                            <div><%= order.delivery.address.street %></div>
                                            <div><%= order.delivery.address.city %>, <%= order.delivery.address.state %> <%= order.delivery.address.zipCode %></div>
                                        </div>
                                    </div>
                                <% } %>
                                <% if (order.delivery.instructions) { %>
                                    <div class="flex items-start">
                                        <svg class="w-5 h-5 text-primary mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
                                        </svg>
                                        <div>
                                            <div class="font-medium">Instructions:</div>
                                            <div class="text-gray-600"><%= order.delivery.instructions %></div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Order Items -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mt-6">
                        <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Order Items</h3>
                        <div class="space-y-4">
                            <% order.items.forEach(item => { %>
                                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                                    <div class="flex items-center space-x-4">
                                        <img src="/images/<%= item.product.image %>" alt="<%= item.name %>" class="w-16 h-16 object-cover rounded-lg">
                                        <div>
                                            <h4 class="font-medium text-gray-900"><%= item.name %></h4>
                                            <p class="text-sm text-gray-600">Quantity: <%= item.quantity %></p>
                                            <p class="text-sm text-gray-600">$<%= item.price.toFixed(2) %> each</p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <div class="font-semibold text-lg">$<%= item.subtotal.toFixed(2) %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Order Totals -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mt-6">
                        <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Order Summary</h3>
                        <div class="space-y-2">
                            <div class="flex justify-between">
                                <span>Subtotal:</span>
                                <span>$<%= order.totals.subtotal.toFixed(2) %></span>
                            </div>
                            <div class="flex justify-between">
                                <span>Tax (8.5%):</span>
                                <span>$<%= order.totals.tax.toFixed(2) %></span>
                            </div>
                            <% if (order.totals.delivery > 0) { %>
                                <div class="flex justify-between">
                                    <span>Delivery:</span>
                                    <span>$<%= order.totals.delivery.toFixed(2) %></span>
                                </div>
                            <% } %>
                            <% if (order.totals.discount > 0) { %>
                                <div class="flex justify-between text-green-600">
                                    <span>Discount:</span>
                                    <span>-$<%= order.totals.discount.toFixed(2) %></span>
                                </div>
                            <% } %>
                            <div class="border-t pt-2 flex justify-between font-bold text-lg">
                                <span>Total:</span>
                                <span class="text-primary">$<%= order.totals.total.toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
    
    <script>
        // Update order status
        async function updateOrderStatus(orderId, status) {
            try {
                const response = await fetch(`/admin/orders/${orderId}/status`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ status })
                });

                const result = await response.json();

                if (result.success) {
                    // Show success message
                    const successDiv = document.createElement('div');
                    successDiv.className = 'fixed top-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50';
                    successDiv.textContent = 'Order status updated successfully';
                    document.body.appendChild(successDiv);
                    
                    setTimeout(() => {
                        successDiv.remove();
                    }, 3000);
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                console.error('Update status error:', error);
                alert('Failed to update order status');
            }
        }

        // Activate current sidebar link
        document.querySelectorAll('.sidebar-link').forEach(link => {
            if (link.getAttribute('href') === '/admin/orders') {
                link.classList.add('active');
            }
        });
    </script>
</body>
</html>