<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
      .sidebar-link.active { background: rgba(211, 84, 0, 0.1); border-left: 4px solid #d35400; }
    </style>
</head>
<body class="bg-gray-50">
    
    <div class="flex h-screen overflow-hidden">
        <%- include('../../partials/sidebar', { role: role }) %>
        
        <div class="flex-1 flex flex-col overflow-hidden">
            <%- include('../../partials/topnav', { username: username, title: title, role: role }) %>
            
            <main class="flex-1 overflow-y-auto p-6">
                <div class="max-w-4xl mx-auto">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 mb-6">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6">Upload Images</h2>
                        
                        <form action="/admin/images/upload" method="POST" enctype="multipart/form-data" class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Select Images</label>
                                <input 
                                    type="file" 
                                    name="images" 
                                    multiple 
                                    accept="image/jpeg,image/jpg,image/png,image/gif,image/webp"
                                    required
                                    class="block w-full text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:border-primary p-3"
                                >
                                <p class="mt-2 text-sm text-gray-500">Accepted: JPG, JPEG, PNG, GIF, WEBP. Max 5MB per file. Up to 10 files.</p>
                            </div>
                            
                            <div class="flex gap-4">
                                <button type="submit" class="flex-1 px-6 py-3 bg-primary hover:bg-secondary text-white rounded-lg transition font-medium">
                                    Upload Images
                                </button>
                                <a href="/admin/images/gallery" class="flex-1 px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg transition font-medium text-center">
                                    View Gallery
                                </a>
                            </div>
                        </form>
                    </div>
                    
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4">Current Images (<%= images.length %>)</h3>
                        <% if (images.length > 0) { %>
                            <div class="grid grid-cols-4 gap-4">
                                <% images.slice(0, 12).forEach(image => { %>
                                    <div class="relative group">
                                        <img src="/images/<%= image %>" alt="<%= image %>" class="w-full h-32 object-cover rounded-lg">
                                        <div class="absolute inset-0 bg-black bg-opacity-50 opacity-0 group-hover:opacity-100 transition rounded-lg flex items-center justify-center">
                                            <p class="text-white text-xs text-center px-2"><%= image %></p>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                            <% if (images.length > 12) { %>
                                <p class="text-center mt-4 text-gray-500">And <%= images.length - 12 %> more...</p>
                            <% } %>
                        <% } else { %>
                            <p class="text-gray-500 text-center py-8">No images uploaded yet</p>
                        <% } %>
                    </div>
                </div>
            </main>
        </div>
    </div>
    
    <script src="/js/admin.js"></script>
</body>
</html>
