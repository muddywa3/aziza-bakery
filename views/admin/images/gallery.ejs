<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
      .sidebar-link.active { background: rgba(211, 84, 0, 0.1); border-left: 4px solid #d35400; }
    </style>
</head>
<body class="bg-gray-50">
    
    <div class="flex h-screen overflow-hidden">
        <%- include('../../partials/sidebar', { role: role }) %>
        
        <div class="flex-1 flex flex-col overflow-hidden">
            <%- include('../../partials/topnav', { username: username, title: title, role: role }) %>
            
            <main class="flex-1 overflow-y-auto p-6">
                <div class="mb-6 flex justify-between items-center">
                    <h1 class="text-2xl font-bold text-gray-900">Image Gallery (<%= images.length %>)</h1>
                    <a href="/admin/images/upload" class="px-6 py-3 bg-primary hover:bg-secondary text-white rounded-lg transition font-medium">
                        Upload Images
                    </a>
                </div>
                
                <% if (images.length > 0) { %>
                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
                        <% images.forEach(image => { %>
                            <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition">
                                <img src="/images/<%= image %>" alt="<%= image %>" class="w-full h-48 object-cover">
                                <div class="p-4">
                                    <p class="text-sm text-gray-700 truncate mb-3" title="<%= image %>"><%= image %></p>
                                    <% if (role === 'admin' || role === 'super_admin') { %>
                                        <button onclick="confirmDelete('/admin/images/<%= image %>/delete', '<%= image %>')" class="w-full px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg transition text-sm font-medium">
                                            Delete
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
                        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <h3 class="text-lg font-medium text-gray-900 mb-2">No images yet</h3>
                        <p class="text-gray-500 mb-6">Upload your first image to get started</p>
                        <a href="/admin/images/upload" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-secondary text-white rounded-lg transition font-medium">
                            Upload Images
                        </a>
                    </div>
                <% } %>
            </main>
        </div>
    </div>
    
    <script src="/js/admin.js"></script>
</body>
</html>
