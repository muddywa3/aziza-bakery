<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin - Aziza Bakery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
              cream: '#f8f0e3',
            }
          }
        }
      }
    </script>
    <style>
      /* Custom SweetAlert styling to match bakery theme */
      .swal2-popup {
        border-radius: 1rem;
        font-family: system-ui, -apple-system, sans-serif;
      }
      .swal2-confirm {
        background-color: #d35400 !important;
        border-radius: 0.5rem;
        padding: 0.75rem 2rem;
        font-weight: 600;
      }
      .swal2-confirm:hover {
        background-color: #e67e22 !important;
      }
      .swal2-cancel {
        background-color: #6b7280 !important;
        border-radius: 0.5rem;
        padding: 0.75rem 2rem;
        font-weight: 600;
      }
      .swal2-icon.swal2-warning {
        border-color: #d35400;
        color: #d35400;
      }
    </style>
</head>
<body class="bg-cream min-h-screen">

<!-- Navigation -->
<nav class="bg-gray-900 sticky top-0 z-50 shadow-lg">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center py-4">
      <a href="/" class="text-white text-2xl font-bold">🍰 Aziza Bakery - Admin</a>
      <div class="hidden md:flex space-x-6">
        <a href="/" class="text-gray-300 hover:text-white transition">Home</a>
        <a href="/gallery" class="text-gray-300 hover:text-white transition">Gallery</a>
        <a href="/admin" class="text-white font-semibold">Admin</a>
        <a href="/logout" class="text-red-400 hover:text-red-300 transition">Logout</a>
      </div>
    </div>
  </div>
</nav>

<!-- Header -->
<div class="bg-gradient-to-r from-primary to-secondary text-white py-16 text-center mb-12">
  <h1 class="text-4xl font-bold mb-2">Admin Panel</h1>
  <p class="text-lg opacity-95">Upload new images to the gallery</p>
</div>

<!-- Admin Content -->
<div class="container mx-auto px-4 pb-20 max-w-4xl">
  
  <!-- Success Message -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-6 py-4 rounded-lg mb-8 flex items-center">
      <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      <span class="font-semibold">Success! <%= uploadedCount %> image(s) uploaded successfully.</span>
    </div>
  <% } %>

  <!-- Error Message -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-6 py-4 rounded-lg mb-8 flex items-center">
      <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span class="font-semibold"><%= error %></span>
    </div>
  <% } %>

  <!-- Upload Form -->
  <div class="bg-white rounded-2xl shadow-xl p-8 mb-12">
    <h2 class="text-3xl font-bold text-gray-800 mb-6">Upload Images</h2>
    
    <form action="/admin/upload" method="POST" enctype="multipart/form-data" class="space-y-6">
      
      <div>
        <label class="block text-gray-700 font-semibold mb-3">Select Images</label>
        <input 
          type="file" 
          name="images" 
          multiple 
          accept="image/jpeg,image/jpg,image/png,image/gif"
          required
          class="block w-full text-gray-700 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 focus:outline-none focus:border-primary p-3"
        >
        <p class="mt-2 text-sm text-gray-500">Accepted formats: JPG, JPEG, PNG, GIF. You can select multiple images.</p>
      </div>

      <div class="flex gap-4">
        <button 
          type="submit" 
          class="flex-1 bg-primary hover:bg-secondary text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-lg"
        >
          Upload Images
        </button>
        <a 
          href="/gallery" 
          class="flex-1 bg-gray-600 hover:bg-gray-700 text-white font-bold py-4 px-8 rounded-lg text-center transition-all duration-300"
        >
          View Gallery
        </a>
      </div>
    </form>
  </div>

  <!-- Current Images -->
  <div class="bg-white rounded-2xl shadow-xl p-8">
    <h2 class="text-3xl font-bold text-gray-800 mb-6">Current Images (<%= images.length %>)</h2>
    
    <% if (images.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% images.forEach(image => { %>
          <div class="bg-gray-50 rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow image-card" data-image="<%= image %>">
            <img 
              src="/images/<%= image %>" 
              alt="<%= image %>" 
              class="w-full h-48 object-cover"
            >
            <div class="p-4">
              <p class="text-gray-700 text-sm font-medium mb-3 truncate" title="<%= image %>"><%= image %></p>
              <button 
                type="button"
                onclick="confirmDelete(this.closest('.image-card'), '<%= image %>')"
                class="w-full bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors duration-200 flex items-center justify-center gap-2"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-gray-500 text-center py-8">No images uploaded yet. Upload your first image above!</p>
    <% } %>
  </div>

</div>

<!-- Footer -->
<footer class="bg-gray-900 text-white text-center py-8 mt-auto">
  <p class="mb-2">© 2026 Aziza Bakery | Admin Panel</p>
</footer>

<script>
  function confirmDelete(imageCard, imageName) {
    // Extract display name from filename
    const displayName = imageName.replace(/\.(jpg|jpeg|png|gif)$/i, '')
                                 .replace(/-/g, ' ')
                                 .replace(/^\d+\s*/, '');
    
    Swal.fire({
      title: 'Delete Image?',
      html: `Are you sure you want to delete<br/><strong>${displayName || imageName}</strong>?<br/><br/>This action cannot be undone.`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, Delete It',
      cancelButtonText: 'Cancel',
      reverseButtons: true,
      focusCancel: true,
      customClass: {
        confirmButton: 'swal2-confirm',
        cancelButton: 'swal2-cancel'
      }
    }).then((result) => {
      if (result.isConfirmed) {
        // Show loading state
        Swal.fire({
          title: 'Deleting...',
          text: 'Please wait while we remove the image',
          icon: 'info',
          allowOutsideClick: false,
          allowEscapeKey: false,
          showConfirmButton: false,
          didOpen: () => {
            Swal.showLoading();
          }
        });
        
        // Send AJAX request to delete image
        fetch(`/delete-image/${encodeURIComponent(imageName)}`, {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Remove the image card from DOM with animation
            imageCard.style.transition = 'all 0.3s ease';
            imageCard.style.opacity = '0';
            imageCard.style.transform = 'scale(0.8)';
            
            setTimeout(() => {
              imageCard.remove();
              
              // Update image count
              const countElement = document.querySelector('h2.text-3xl');
              const currentCount = parseInt(countElement.textContent.match(/\d+/)[0]);
              const newCount = currentCount - 1;
              countElement.textContent = `Current Images (${newCount})`;
              
              // Show empty state if no images left
              if (newCount === 0) {
                const gridContainer = document.querySelector('.grid');
                gridContainer.innerHTML = '<p class="text-gray-500 text-center py-8 col-span-full">No images uploaded yet. Upload your first image above!</p>';
              }
              
              // Show success message
              Swal.fire({
                title: 'Deleted!',
                text: 'Image has been deleted successfully',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false,
                toast: true,
                position: 'top-end',
                customClass: {
                  popup: 'colored-toast'
                }
              });
            }, 300);
          } else {
            // Show error message
            Swal.fire({
              title: 'Error!',
              text: data.message || 'Failed to delete image',
              icon: 'error',
              confirmButtonText: 'OK',
              customClass: {
                confirmButton: 'swal2-confirm'
              }
            });
          }
        })
        .catch(error => {
          console.error('Delete error:', error);
          Swal.fire({
            title: 'Error!',
            text: 'Network error. Please try again.',
            icon: 'error',
            confirmButtonText: 'OK',
            customClass: {
              confirmButton: 'swal2-confirm'
            }
          });
        });
      }
    });
  }
</script>

</body>
</html>
