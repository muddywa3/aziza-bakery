<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Aziza Bakery - Artisan Baked Goods</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
              cream: '#faf8f5',
              gold: '#d4af37',
              dark: '#1a1a1a',
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            },
            spacing: {
              '18': '4.5rem',
              '22': '5.5rem',
              '26': '6.5rem',
              '30': '7.5rem',
            }
          }
        }
      }
    </script>
    <style>
      .hero-bg {
        background: linear-gradient(135deg, rgba(211, 84, 0, 0.95) 0%, rgba(230, 126, 34, 0.9) 100%),
                    url('https://images.unsplash.com/photo-1509440159596-0249088772ff?w=1920&q=80') center/cover;
      }
      
      /* Smooth underline animation */
      .nav-link {
        position: relative;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 2px;
        background: #d4af37;
        transition: width 0.3s ease;
      }
      .nav-link:hover::after,
      .nav-link.active::after {
        width: 100%;
      }
      
      /* Navbar scroll shadow */
      .navbar-scrolled {
        background: rgba(17, 24, 39, 0.95);
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }
      
      /* Mobile menu animation */
      .mobile-menu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
      }
      .mobile-menu.open {
        max-height: 500px;
      }
      
      /* Fade-in animations */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      
      .fade-in {
        animation: fadeIn 0.8s ease forwards;
      }
      
      .fade-in-up {
        animation: fadeInUp 0.8s ease forwards;
      }
      
      /* Scroll reveal animation */
      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      
      .reveal.active {
        opacity: 1;
        transform: translateY(0);
      }
      
      /* Staggered animation for cards */
      .reveal:nth-child(1) { transition-delay: 0.1s; }
      .reveal:nth-child(2) { transition-delay: 0.2s; }
      .reveal:nth-child(3) { transition-delay: 0.3s; }
      
      /* Image zoom on hover */
      .zoom-image {
        overflow: hidden;
      }
      .zoom-image img {
        transition: transform 0.5s ease;
      }
      .zoom-image:hover img {
        transform: scale(1.08);
      }
    </style>
</head>
<body class="font-body bg-white">

<!-- Enhanced Navigation -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex justify-between items-center py-5">
      <!-- Brand -->
      <a href="/" class="text-white text-2xl lg:text-3xl font-display font-bold tracking-wide hover:text-gold transition-colors duration-300">
        Aziza Bakery
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8 lg:space-x-10">
        <a href="/" class="nav-link active text-white font-semibold hover:text-gold transition-colors duration-300 pb-1">Home</a>
        <a href="/gallery" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Gallery</a>
        <a href="/menu" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Menu</a>
        <a href="/contact" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Contact</a>
        <a href="/order" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Order Online</a>
        <a href="/admin" class="px-5 py-2 bg-gold/20 hover:bg-gold/30 text-white rounded-full text-sm font-medium transition-all duration-300 border border-gold/30">
          Admin
        </a>
      </div>
      
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden text-white focus:outline-none">
        <svg id="menu-icon" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="mobile-menu md:hidden">
      <div class="py-4 space-y-4 border-t border-white/10">
        <a href="/" class="block text-white font-semibold hover:text-gold transition-colors duration-300 py-2">Home</a>
        <a href="/gallery" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Gallery</a>
        <a href="/menu" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Menu</a>
        <a href="/contact" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Contact</a>
        <a href="/order" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Order Online</a>
        <a href="/admin" class="block text-white/90 hover:text-white transition-colors duration-300 py-2 border-t border-white/10 pt-4">Admin Panel</a>
      </div>
    </div>
  </div>
</nav>

<!-- Hero Section -->
<section class="hero-bg min-h-screen flex items-center justify-center relative">
  <!-- Decorative Elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 right-10 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-6 lg:px-16 text-center relative z-10 py-32">
    <!-- Badge -->
    <div class="inline-block mb-10 fade-in">
      <span class="bg-white/20 backdrop-blur-sm text-white px-8 py-3 rounded-full text-sm font-medium tracking-widest uppercase border border-white/30">
        Est. 2020 • Artisan Bakery
      </span>
    </div>
    
    <!-- Main Headline -->
    <h1 class="font-display text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-bold text-white mb-10 leading-tight fade-in-up tracking-tight">
      Handcrafted<br/>
      <span class="text-gold">Perfection</span>
    </h1>
    
    <!-- Subtitle -->
    <p class="text-white/95 text-xl md:text-2xl lg:text-3xl mb-16 max-w-4xl mx-auto font-light leading-relaxed fade-in-up" style="animation-delay: 0.2s;">
      Where tradition meets innovation in every bite.<br class="hidden md:block"/>
      Freshly baked daily with premium ingredients and passion.
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-6 justify-center items-center fade-in-up" style="animation-delay: 0.4s;">
      <a href="/order" class="group relative inline-flex items-center justify-center px-12 py-6 bg-white text-primary font-bold text-lg rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-2xl min-w-[220px]">
        <span class="absolute inset-0 bg-gradient-to-r from-primary to-secondary transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
        <span class="relative z-10 group-hover:text-white transition-colors">Order Online</span>
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a href="/menu" class="group relative inline-flex items-center justify-center px-12 py-6 bg-white text-primary font-bold text-lg rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-2xl min-w-[220px]">
        <span class="relative z-10">View Menu</span>
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      
      <a href="/gallery" class="group inline-flex items-center justify-center px-12 py-6 bg-transparent text-white font-semibold text-lg rounded-full border-2 border-white/50 backdrop-blur-sm hover:bg-white/10 hover:border-white transition-all duration-300 min-w-[220px]">
        <span>Visit Gallery</span>
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </div>
</section>

<!-- Featured Products Section -->
<section class="py-28 lg:py-36 bg-cream">
  <div class="container mx-auto px-6 lg:px-16">
    <!-- Section Header -->
    <div class="text-center mb-24 reveal">
      <span class="text-primary font-semibold tracking-widest uppercase text-sm mb-6 block">Our Specialties</span>
      <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-8 tracking-tight">
        Latest Creations
      </h2>
      <p class="text-gray-600 text-lg md:text-xl lg:text-2xl max-w-3xl mx-auto leading-relaxed">
        Discover our freshly baked masterpieces, crafted with passion and the finest ingredients
      </p>
    </div>
    
    <% if (images.length > 0) { %>
      <!-- Products Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12 mb-20">
        <% images.slice(0, 3).forEach((image, index) => { %>
          <div class="reveal group relative bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-3">
            <!-- Image -->
            <div class="zoom-image relative overflow-hidden aspect-[4/3]">
              <img src="/images/<%= image %>" alt="<%= image %>" class="w-full h-full object-cover" loading="lazy">
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            
            <!-- Content -->
            <div class="p-10">
              <h3 class="font-display text-3xl lg:text-4xl font-bold text-gray-900 mb-4 tracking-tight">
                <%= image.replace(/\.(jpg|jpeg|png|gif)$/i, '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
              </h3>
              <p class="text-gray-600 mb-8 text-base leading-relaxed">Handcrafted with premium ingredients and baked fresh daily</p>
              <div class="flex items-center text-primary font-semibold group-hover:text-secondary transition-colors text-lg">
                <span>Learn More</span>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      
      <% if (images.length > 3) { %>
        <!-- View All Button -->
        <div class="text-center reveal">
          <a href="/gallery" class="inline-flex items-center justify-center px-14 py-6 bg-primary hover:bg-secondary text-white font-bold text-lg rounded-full transition-all duration-300 hover:scale-105 hover:shadow-xl">
            <span>View All <%= images.length %> Products</span>
            <svg class="w-5 h-5 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-24 bg-white rounded-3xl reveal">
        <div class="text-7xl mb-8">🍰</div>
        <h3 class="font-display text-3xl font-bold text-gray-800 mb-4">Coming Soon</h3>
        <p class="text-gray-600 text-xl">Our delicious creations are on their way!</p>
      </div>
    <% } %>
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-900 text-white py-20 lg:py-24">
  <div class="container mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-16">
      <!-- Brand -->
      <div>
        <h3 class="font-display text-4xl font-bold mb-6">Aziza Bakery</h3>
        <p class="text-gray-400 leading-relaxed text-base mb-8">Crafting memorable moments through exceptional baked goods since 2020.</p>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold text-xl mb-6 text-white">Quick Links</h4>
        <ul class="space-y-4">
          <li><a href="/" class="text-gray-400 hover:text-white transition text-base">Home</a></li>
          <li><a href="/gallery" class="text-gray-400 hover:text-white transition text-base">Gallery</a></li>
          <li><a href="/menu" class="text-gray-400 hover:text-white transition text-base">Menu</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-white transition text-base">Contact</a></li>
          <li><a href="/order" class="text-gray-400 hover:text-white transition text-base">Order Online</a></li>
        </ul>
      </div>
      
      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-xl mb-6 text-white">Get In Touch</h4>
        <ul class="space-y-4 text-gray-400 text-base">
          <li>📍 123 Bakery Street, Sweet City</li>
          <li>📞 +1 (555) 123-4567</li>
          <li>📧 hello@azizabakery.com</li>
          <li>🕒 Mon-Sat: 7:00 AM - 8:00 PM</li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-800 pt-10 text-center text-gray-400">
      <p class="text-base">© 2026 Aziza Bakery. All rights reserved. Made with ❤️</p>
    </div>
  </div>
</footer>

<script>
  // Navbar scroll effect
  window.addEventListener('scroll', function() {
    const navbar = document.getElementById('navbar');
    if (window.scrollY > 50) {
      navbar.classList.add('navbar-scrolled');
    } else {
      navbar.classList.remove('navbar-scrolled');
    }
  });
  
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  
  mobileMenuBtn.addEventListener('click', function() {
    mobileMenu.classList.toggle('open');
    menuIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });
  
  // Scroll reveal animation
  function reveal() {
    const reveals = document.querySelectorAll('.reveal');
    
    reveals.forEach(element => {
      const windowHeight = window.innerHeight;
      const elementTop = element.getBoundingClientRect().top;
      const elementVisible = 150;
      
      if (elementTop < windowHeight - elementVisible) {
        element.classList.add('active');
      }
    });
  }
  
  window.addEventListener('scroll', reveal);
  reveal(); // Trigger on page load
</script>

</body>
</html>
