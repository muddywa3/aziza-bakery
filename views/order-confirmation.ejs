<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
              cream: '#faf8f5',
              gold: '#d4af37'
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in-up { animation: fadeInUp 0.6s ease forwards; }
      .delay-1 { animation-delay: 0.2s; opacity: 0; }
      .delay-2 { animation-delay: 0.4s; opacity: 0; }
    </style>
</head>
<body class="bg-cream">

    <!-- Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <a href="/" class="font-display text-2xl font-bold text-primary">🍰 Aziza Bakery</a>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="text-gray-700 hover:text-primary transition">Home</a>
                    <a href="/menu" class="text-gray-700 hover:text-primary transition">Menu</a>
                    <a href="/gallery" class="text-gray-700 hover:text-primary transition">Gallery</a>
                    <a href="/contact" class="text-gray-700 hover:text-primary transition">Contact</a>
                    <a href="/order" class="text-gray-700 hover:text-primary transition">Order Online</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Success Header -->
    <div class="bg-gradient-to-r from-green-500 to-green-600 text-white py-16">
        <div class="max-w-4xl mx-auto px-4 text-center animate-fade-in-up">
            <div class="text-6xl mb-4">✅</div>
            <h1 class="font-display text-5xl font-bold mb-4">Order Confirmed!</h1>
            <p class="text-xl opacity-90">Thank you for your order. We're preparing your delicious treats!</p>
        </div>
    </div>

    <!-- Order Details -->
    <div class="max-w-4xl mx-auto px-4 py-12">
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden animate-fade-in-up delay-1">
            
            <!-- Order Header -->
            <div class="bg-primary text-white px-8 py-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h2 class="font-display text-2xl font-bold">Order #<%= order.orderNumber %></h2>
                        <p class="opacity-90">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-US', { 
                            weekday: 'long', 
                            year: 'numeric', 
                            month: 'long', 
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        }) %></p>
                    </div>
                    <div class="text-right">
                        <div class="text-3xl font-bold">$<%= order.totals.total.toFixed(2) %></div>
                        <div class="capitalize px-3 py-1 bg-white bg-opacity-20 rounded-full text-sm">
                            <%= order.status.replace('_', ' ') %>
                        </div>
                    </div>
                </div>
                
                <!-- Tracking Code Section -->
                <div class="mt-6 pt-6 border-t border-white border-opacity-20">
                    <div class="bg-white bg-opacity-10 rounded-lg p-4">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3 class="font-semibold text-lg mb-1">Track Your Order</h3>
                                <p class="text-sm opacity-90">Use this code to track your order status</p>
                            </div>
                            <div class="text-right">
                                <div class="font-mono text-2xl font-bold bg-white text-primary px-4 py-2 rounded-lg">
                                    <%= order.trackingCode %>
                                </div>
                                <button onclick="copyTrackingCode()" class="text-sm opacity-90 hover:opacity-100 transition mt-1">
                                    📋 Click to copy
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    
                    <!-- Customer Information -->
                    <div>
                        <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Customer Information</h3>
                        <div class="space-y-3 text-gray-700">
                            <div class="flex items-center">
                                <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <span><%= order.customer.name %></span>
                            </div>
                            <div class="flex items-center">
                                <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                <span><%= order.customer.email %></span>
                            </div>
                            <div class="flex items-center">
                                <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                                <span><%= order.customer.phone %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Delivery Information -->
                    <div>
                        <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Delivery Information</h3>
                        <div class="space-y-3 text-gray-700">
                            <div class="flex items-center">
                                <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0V6a2 2 0 012-2h4a2 2 0 012 2v1m-6 0h8m-8 0H6a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-2"/>
                                </svg>
                                <span class="capitalize"><%= order.delivery.type %></span>
                            </div>
                            <div class="flex items-center">
                                <svg class="w-5 h-5 text-primary mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <span><%= new Date(order.delivery.scheduledFor).toLocaleDateString('en-US', { 
                                    weekday: 'long', 
                                    year: 'numeric', 
                                    month: 'long', 
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                }) %></span>
                            </div>
                            <% if (order.delivery.type === 'delivery' && order.delivery.address) { %>
                                <div class="flex items-start">
                                    <svg class="w-5 h-5 text-primary mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    <div>
                                        <div><%= order.delivery.address.street %></div>
                                        <div><%= order.delivery.address.city %>, <%= order.delivery.address.state %> <%= order.delivery.address.zipCode %></div>
                                    </div>
                                </div>
                            <% } %>
                            <% if (order.delivery.instructions) { %>
                                <div class="flex items-start">
                                    <svg class="w-5 h-5 text-primary mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
                                    </svg>
                                    <div>
                                        <div class="font-medium">Special Instructions:</div>
                                        <div class="text-gray-600"><%= order.delivery.instructions %></div>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="mt-8">
                    <h3 class="font-display text-xl font-semibold text-gray-900 mb-4">Order Items</h3>
                    <div class="space-y-4">
                        <% order.items.forEach(item => { %>
                            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                                <div class="flex items-center space-x-4">
                                    <img src="/images/<%= item.product.image %>" alt="<%= item.name %>" class="w-16 h-16 object-cover rounded-lg">
                                    <div>
                                        <h4 class="font-medium text-gray-900"><%= item.name %></h4>
                                        <p class="text-sm text-gray-600">Quantity: <%= item.quantity %></p>
                                        <p class="text-sm text-gray-600">$<%= item.price.toFixed(2) %> each</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="font-semibold text-lg">$<%= item.subtotal.toFixed(2) %></div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Order Totals -->
                <div class="mt-8 bg-gray-50 rounded-lg p-6">
                    <div class="space-y-2">
                        <div class="flex justify-between">
                            <span>Subtotal:</span>
                            <span>$<%= order.totals.subtotal.toFixed(2) %></span>
                        </div>
                        <div class="flex justify-between">
                            <span>Tax (8.5%):</span>
                            <span>$<%= order.totals.tax.toFixed(2) %></span>
                        </div>
                        <% if (order.totals.delivery > 0) { %>
                            <div class="flex justify-between">
                                <span>Delivery:</span>
                                <span>$<%= order.totals.delivery.toFixed(2) %></span>
                            </div>
                        <% } %>
                        <% if (order.totals.discount > 0) { %>
                            <div class="flex justify-between text-green-600">
                                <span>Discount:</span>
                                <span>-$<%= order.totals.discount.toFixed(2) %></span>
                            </div>
                        <% } %>
                        <div class="border-t pt-2 flex justify-between font-bold text-lg">
                            <span>Total:</span>
                            <span class="text-primary">$<%= order.totals.total.toFixed(2) %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Next Steps -->
        <div class="mt-8 bg-white rounded-2xl shadow-lg p-8 animate-fade-in-up delay-2">
            <h3 class="font-display text-2xl font-semibold text-gray-900 mb-6 text-center">What Happens Next?</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">1</div>
                    <h4 class="font-semibold text-gray-900 mb-2">Order Confirmation</h4>
                    <p class="text-gray-600 text-sm">You'll receive an email confirmation shortly with your order details.</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-secondary text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">2</div>
                    <h4 class="font-semibold text-gray-900 mb-2">Preparation</h4>
                    <p class="text-gray-600 text-sm">Our bakers will start preparing your fresh items with love and care.</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-gold text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">3</div>
                    <h4 class="font-semibold text-gray-900 mb-2"><%= order.delivery.type === 'delivery' ? 'Delivery' : 'Pickup' %></h4>
                    <p class="text-gray-600 text-sm">
                        <% if (order.delivery.type === 'delivery') { %>
                            We'll deliver your order to your specified address at the scheduled time.
                        <% } else { %>
                            Your order will be ready for pickup at the scheduled time.
                        <% } %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="mt-8 text-center space-x-4">
            <a href="/track" class="inline-block px-8 py-3 bg-gold hover:bg-yellow-600 text-white rounded-lg font-semibold transition">
                Track This Order
            </a>
            <a href="/" class="inline-block px-8 py-3 bg-primary hover:bg-secondary text-white rounded-lg font-semibold transition">
                Back to Home
            </a>
            <a href="/order" class="inline-block px-8 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg font-semibold transition">
                Place Another Order
            </a>
        </div>
    </div>

    <script>
        function copyTrackingCode() {
            const trackingCode = '<%= order.trackingCode %>';
            navigator.clipboard.writeText(trackingCode).then(function() {
                // Show success message
                const button = event.target;
                const originalText = button.textContent;
                button.textContent = '✅ Copied!';
                button.style.color = '#10B981';
                
                setTimeout(() => {
                    button.textContent = originalText;
                    button.style.color = '';
                }, 2000);
            }).catch(function(err) {
                console.error('Could not copy text: ', err);
                // Fallback for older browsers
                const textArea = document.createElement('textarea');
                textArea.value = trackingCode;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                
                const button = event.target;
                const originalText = button.textContent;
                button.textContent = '✅ Copied!';
                setTimeout(() => {
                    button.textContent = originalText;
                }, 2000);
            });
        }
    </script>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12 mt-16">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="font-display text-2xl font-bold mb-4">🍰 Aziza Bakery</div>
            <p class="text-gray-400 mb-4">Fresh baked goods made with love</p>
            <div class="flex justify-center space-x-6 text-sm">
                <a href="/" class="hover:text-primary transition">Home</a>
                <a href="/menu" class="hover:text-primary transition">Menu</a>
                <a href="/gallery" class="hover:text-primary transition">Gallery</a>
                <a href="/contact" class="hover:text-primary transition">Contact</a>
            </div>
            <div class="mt-8 pt-8 border-t border-gray-800 text-gray-500 text-sm">
                <p>&copy; 2026 Aziza Bakery. All rights reserved.</p>
            </div>
        </div>
    </footer>
</body>
</html>