<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
              cream: '#faf8f5',
              gold: '#d4af37'
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
    </style>
</head>
<body class="bg-cream">

    <%- include('../partials/navbar', { currentPage: 'track' }) %>

    <!-- Header -->
    <div class="bg-gradient-to-r from-primary to-secondary text-white py-16 mt-20">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="text-6xl mb-6">📦</div>
            <h1 class="text-4xl font-bold mb-4">Track Your Order</h1>
            <p class="text-xl">Enter your tracking code to see your order status</p>
        </div>
    </div>

    <!-- Tracking Form -->
    <div class="max-w-2xl mx-auto px-4 py-16">
        <div class="bg-white rounded-2xl shadow-xl p-8">
            
            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 flex items-center">
                    <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                    <%= error %>
                </div>
            <% } %>

            <% if (success) { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 flex items-center">
                    <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <%= success %>
                </div>
            <% } %>

            <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-2">Enter Tracking Code</h2>
                <p class="text-gray-600">Your tracking code was provided in your order confirmation</p>
            </div>

            <form method="POST" action="/track" class="space-y-6">
                <div>
                    <label for="trackingCode" class="block text-sm font-medium text-gray-700 mb-2">
                        Tracking Code
                    </label>
                    <input 
                        type="text" 
                        id="trackingCode" 
                        name="trackingCode" 
                        required 
                        placeholder="e.g., AZ1A2B3C4D5E6F"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-lg font-mono uppercase"
                        maxlength="20"
                        style="letter-spacing: 2px;"
                    >
                    <p class="text-sm text-gray-500 mt-2">
                        <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                        </svg>
                        Tracking codes start with "AZ" and are case-insensitive
                    </p>
                </div>

                <button 
                    type="submit" 
                    class="w-full bg-primary hover:bg-secondary text-white font-bold py-4 px-6 rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-lg flex items-center justify-center"
                >
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    Track My Order
                </button>
            </form>

            <!-- Help Section -->
            <div class="mt-8 pt-6 border-t border-gray-200">
                <h3 class="text-lg font-semibold text-gray-800 mb-3">Need Help?</h3>
                <div class="space-y-2 text-sm text-gray-600">
                    <p>• Your tracking code was sent to your email after placing the order</p>
                    <p>• Tracking codes are not case-sensitive</p>
                    <p>• If you can't find your tracking code, please <a href="/contact" class="text-primary hover:underline">contact us</a></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p>&copy; 2026 Aziza Bakery. All rights reserved.</p>
            <div class="mt-4 space-x-4">
                <a href="/" class="text-gray-400 hover:text-white transition">Home</a>
                <a href="/menu" class="text-gray-400 hover:text-white transition">Menu</a>
                <a href="/gallery" class="text-gray-400 hover:text-white transition">Gallery</a>
                <a href="/contact" class="text-gray-400 hover:text-white transition">Contact</a>
            </div>
        </div>
    </footer>

    <script>
        // Auto-uppercase tracking code input
        document.getElementById('trackingCode').addEventListener('input', function(e) {
            e.target.value = e.target.value.toUpperCase();
        });
    </script>

</body>
</html>