<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Aziza Bakery</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
              cream: '#faf8f5',
              gold: '#d4af37'
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Poppins', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      body { font-family: 'Poppins', sans-serif; }
      .progress-bar {
        transition: width 0.8s ease-in-out;
      }
    </style>
</head>
<body class="bg-cream">

    <%- include('../partials/navbar', { currentPage: 'track' }) %>

    <!-- Header -->
    <div class="bg-gradient-to-r from-primary to-secondary text-white py-12 mt-20">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="text-4xl mb-4">✅</div>
            <h1 class="text-3xl font-bold mb-2">Order Found!</h1>
            <p class="text-lg">Tracking Code: <span class="font-mono bg-white/20 px-3 py-1 rounded"><%= trackingCode %></span></p>
        </div>
    </div>

    <!-- Order Status -->
    <div class="max-w-4xl mx-auto px-4 py-12">
        
        <!-- Status Card -->
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-2xl font-bold text-gray-800">Order #<%= order.orderNumber %></h2>
                    <p class="text-gray-600">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    }) %></p>
                </div>
                <div class="text-right">
                    <% 
                        let statusClass, statusText, progressPercent;
                        switch(order.status) {
                            case 'pending':
                                statusClass = 'bg-yellow-100 text-yellow-800 border-yellow-200';
                                statusText = 'Order Received';
                                progressPercent = 20;
                                break;
                            case 'confirmed':
                                statusClass = 'bg-blue-100 text-blue-800 border-blue-200';
                                statusText = 'Order Confirmed';
                                progressPercent = 40;
                                break;
                            case 'preparing':
                                statusClass = 'bg-orange-100 text-orange-800 border-orange-200';
                                statusText = 'Being Prepared';
                                progressPercent = 60;
                                break;
                            case 'ready':
                                statusClass = 'bg-purple-100 text-purple-800 border-purple-200';
                                statusText = 'Ready for Pickup';
                                progressPercent = 80;
                                break;
                            case 'completed':
                                statusClass = 'bg-green-100 text-green-800 border-green-200';
                                statusText = 'Completed';
                                progressPercent = 100;
                                break;
                            case 'cancelled':
                                statusClass = 'bg-red-100 text-red-800 border-red-200';
                                statusText = 'Cancelled';
                                progressPercent = 0;
                                break;
                            default:
                                statusClass = 'bg-gray-100 text-gray-800 border-gray-200';
                                statusText = order.status;
                                progressPercent = 0;
                        }
                    %>
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border <%= statusClass %>">
                        <%= statusText %>
                    </span>
                </div>
            </div>

            <!-- Progress Bar -->
            <div class="mb-8">
                <div class="flex justify-between text-sm text-gray-600 mb-2">
                    <span>Order Progress</span>
                    <span><%= progressPercent %>%</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-3">
                    <div class="progress-bar bg-gradient-to-r from-primary to-secondary h-3 rounded-full" style="width: <%= progressPercent %>%"></div>
                </div>
            </div>

            <!-- Order Timeline -->
            <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
                <div class="text-center">
                    <div class="w-10 h-10 mx-auto rounded-full <%= progressPercent >= 20 ? 'bg-primary text-white' : 'bg-gray-200 text-gray-500' %> flex items-center justify-center mb-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <p class="text-xs text-gray-600">Received</p>
                </div>
                <div class="text-center">
                    <div class="w-10 h-10 mx-auto rounded-full <%= progressPercent >= 40 ? 'bg-primary text-white' : 'bg-gray-200 text-gray-500' %> flex items-center justify-center mb-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <p class="text-xs text-gray-600">Confirmed</p>
                </div>
                <div class="text-center">
                    <div class="w-10 h-10 mx-auto rounded-full <%= progressPercent >= 60 ? 'bg-primary text-white' : 'bg-gray-200 text-gray-500' %> flex items-center justify-center mb-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
                        </svg>
                    </div>
                    <p class="text-xs text-gray-600">Preparing</p>
                </div>
                <div class="text-center">
                    <div class="w-10 h-10 mx-auto rounded-full <%= progressPercent >= 80 ? 'bg-primary text-white' : 'bg-gray-200 text-gray-500' %> flex items-center justify-center mb-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <p class="text-xs text-gray-600">Ready</p>
                </div>
                <div class="text-center">
                    <div class="w-10 h-10 mx-auto rounded-full <%= progressPercent >= 100 ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-500' %> flex items-center justify-center mb-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <p class="text-xs text-gray-600">Completed</p>
                </div>
            </div>
        </div>

        <!-- Order Details -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- Customer & Delivery Info -->
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h3 class="text-xl font-bold text-gray-800 mb-4">Order Details</h3>
                
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-gray-600">Customer</p>
                        <p class="font-semibold"><%= order.customer.name %></p>
                        <p class="text-sm text-gray-600"><%= order.customer.email %></p>
                        <p class="text-sm text-gray-600"><%= order.customer.phone %></p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-600">Delivery Type</p>
                        <p class="font-semibold capitalize">
                            <%= order.delivery.type %>
                            <% if (order.delivery.type === 'pickup') { %>
                                <span class="text-sm text-gray-600">- Store Pickup</span>
                            <% } %>
                        </p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-600">Scheduled For</p>
                        <p class="font-semibold">
                            <%= new Date(order.delivery.scheduledFor).toLocaleDateString('en-US', { 
                                year: 'numeric', 
                                month: 'long', 
                                day: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                            }) %>
                        </p>
                    </div>
                    
                    <% if (order.specialInstructions) { %>
                    <div>
                        <p class="text-sm text-gray-600">Special Instructions</p>
                        <p class="text-sm bg-gray-50 p-3 rounded-lg"><%= order.specialInstructions %></p>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Order Items -->
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h3 class="text-xl font-bold text-gray-800 mb-4">Order Items</h3>
                
                <div class="space-y-3 mb-4">
                    <% order.items.forEach(item => { %>
                        <div class="flex justify-between items-center py-2 border-b border-gray-100">
                            <div class="flex items-center">
                                <% if (item.image) { %>
                                    <img src="/images/<%= item.image %>" alt="<%= item.name %>" class="w-12 h-12 object-cover rounded-lg mr-3">
                                <% } %>
                                <div>
                                    <p class="font-medium"><%= item.name %></p>
                                    <p class="text-sm text-gray-600">Qty: <%= item.quantity %> × $<%= item.price.toFixed(2) %></p>
                                </div>
                            </div>
                            <p class="font-semibold">$<%= (item.price * item.quantity).toFixed(2) %></p>
                        </div>
                    <% }) %>
                </div>

                <!-- Order Total -->
                <div class="border-t border-gray-200 pt-4">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-gray-600">Subtotal:</span>
                        <span>$<%= order.totals.subtotal.toFixed(2) %></span>
                    </div>
                    <% if (order.totals.tax > 0) { %>
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-gray-600">Tax:</span>
                        <span>$<%= order.totals.tax.toFixed(2) %></span>
                    </div>
                    <% } %>
                    <% if (order.totals.delivery > 0) { %>
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-gray-600">Delivery:</span>
                        <span>$<%= order.totals.delivery.toFixed(2) %></span>
                    </div>
                    <% } %>
                    <div class="flex justify-between items-center text-lg font-bold border-t border-gray-200 pt-2">
                        <span>Total:</span>
                        <span class="text-primary">$<%= order.totals.total.toFixed(2) %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="text-center mt-8">
            <a href="/track" class="inline-flex items-center px-6 py-3 bg-gray-500 hover:bg-gray-600 text-white font-medium rounded-lg transition mr-4">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Track Another Order
            </a>
            <a href="/contact" class="inline-flex items-center px-6 py-3 bg-primary hover:bg-secondary text-white font-medium rounded-lg transition">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                Contact Us
            </a>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8 mt-12">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p>&copy; 2026 Aziza Bakery. All rights reserved.</p>
            <div class="mt-4 space-x-4">
                <a href="/" class="text-gray-400 hover:text-white transition">Home</a>
                <a href="/menu" class="text-gray-400 hover:text-white transition">Menu</a>
                <a href="/gallery" class="text-gray-400 hover:text-white transition">Gallery</a>
                <a href="/contact" class="text-gray-400 hover:text-white transition">Contact</a>
            </div>
        </div>
    </footer>

</body>
</html>