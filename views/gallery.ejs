<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Gallery - Aziza Bakery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#d35400',
              secondary: '#e67e22',
              cream: '#f8f0e3',
              gold: '#d4af37',
            },
            fontFamily: {
              'display': ['Playfair Display', 'serif'],
              'body': ['Inter', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <style>
      .nav-link {
        position: relative;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 2px;
        background: #d4af37;
        transition: width 0.3s ease;
      }
      .nav-link:hover::after,
      .nav-link.active::after {
        width: 100%;
      }
      
      .navbar-scrolled {
        background: rgba(17, 24, 39, 0.95);
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }
      
      .mobile-menu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
      }
      .mobile-menu.open {
        max-height: 500px;
      }
      
      .gallery-card {
        overflow: hidden;
      }
      .gallery-card img {
        transition: transform 0.5s ease;
      }
      .gallery-card:hover img {
        transform: scale(1.1);
      }
    </style>
</head>
<body class="font-body bg-cream min-h-screen">

<!-- Enhanced Navigation -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-gray-900 transition-all duration-300">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex justify-between items-center py-5">
      <a href="/" class="text-white text-2xl lg:text-3xl font-display font-bold tracking-wide hover:text-gold transition-colors duration-300">
        Aziza Bakery
      </a>
      
      <div class="hidden md:flex items-center space-x-8 lg:space-x-10">
        <a href="/" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Home</a>
        <a href="/gallery" class="nav-link active text-white font-semibold hover:text-gold transition-colors duration-300 pb-1">Gallery</a>
        <a href="/menu" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Menu</a>
        <a href="/contact" class="nav-link text-white/90 hover:text-white transition-colors duration-300 pb-1">Contact</a>
        <a href="/admin" class="px-5 py-2 bg-gold/20 hover:bg-gold/30 text-white rounded-full text-sm font-medium transition-all duration-300 border border-gold/30">
          Admin
        </a>
      </div>
      
      <button id="mobile-menu-btn" class="md:hidden text-white focus:outline-none">
        <svg id="menu-icon" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <div id="mobile-menu" class="mobile-menu md:hidden">
      <div class="py-4 space-y-4 border-t border-white/10">
        <a href="/" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Home</a>
        <a href="/gallery" class="block text-white font-semibold hover:text-gold transition-colors duration-300 py-2">Gallery</a>
        <a href="/menu" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Menu</a>
        <a href="/contact" class="block text-white/90 hover:text-white transition-colors duration-300 py-2">Contact</a>
        <a href="/admin" class="block text-white/90 hover:text-white transition-colors duration-300 py-2 border-t border-white/10 pt-4">Admin Panel</a>
      </div>
    </div>
  </div>
</nav>

<!-- Header Section -->
<section class="pt-32 pb-16 bg-gradient-to-br from-primary via-secondary to-primary">
  <div class="container mx-auto px-6 lg:px-12 text-center">
    <span class="inline-block bg-white/20 backdrop-blur-sm text-white px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase mb-6 border border-white/30">
      Our Collection
    </span>
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6">
      Gallery
    </h1>
    <p class="text-white/95 text-xl md:text-2xl max-w-2xl mx-auto">
      Explore our delicious collection of handcrafted baked goods
    </p>
  </div>
</section>

<!-- Gallery Grid -->
<section class="py-20 lg:py-24">
  <div class="container mx-auto px-6 lg:px-12">
    
    <% if (images.length > 0) { %>
      <div class="mb-12 text-center">
        <p class="text-gray-600 text-lg">
          Showing <span class="font-bold text-primary"><%= images.length %></span> delicious creations
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
        <% images.forEach(image => { %>
          <div class="gallery-card bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
            <div class="relative overflow-hidden rounded-t-2xl aspect-square">
              <img 
                src="/images/<%= image %>" 
                alt="<%= image %>" 
                class="w-full h-full object-cover"
                loading="lazy"
              >
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-end">
                <div class="p-6 w-full">
                  <p class="text-white font-semibold text-lg">
                    <%= image.replace(/\.(jpg|jpeg|png|gif)$/i, '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                  </p>
                </div>
              </div>
            </div>
            
            <div class="p-5">
              <p class="text-gray-700 font-medium text-center truncate">
                <%= image.replace(/\.(jpg|jpeg|png|gif)$/i, '').replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
              </p>
            </div>
          </div>
        <% }) %>
      </div>
      
      <div class="mt-16 text-center">
        <a href="/" class="inline-flex items-center justify-center px-10 py-4 bg-primary hover:bg-secondary text-white font-bold text-lg rounded-full transition-all duration-300 hover:scale-105 hover:shadow-xl">
          <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          <span>Back to Home</span>
        </a>
      </div>
      
    <% } else { %>
      <div class="text-center py-20 bg-white rounded-3xl shadow-lg max-w-2xl mx-auto">
        <div class="text-8xl mb-8">🍰</div>
        <h3 class="font-display text-3xl font-bold text-gray-800 mb-4">No Images Yet</h3>
        <p class="text-gray-600 text-lg mb-8">Our gallery is waiting for delicious creations!</p>
        <a href="/admin" class="inline-flex items-center justify-center px-8 py-4 bg-primary hover:bg-secondary text-white font-bold rounded-full transition-all duration-300">
          Upload Images
        </a>
      </div>
    <% } %>
    
  </div>
</section>

<!-- Footer -->
<footer class="bg-gray-900 text-white py-16 mt-20">
  <div class="container mx-auto px-6 lg:px-12 text-center">
    <p class="mb-2">© 2026 Aziza Bakery. All rights reserved. Made with ❤️</p>
  </div>
</footer>

<script>
  window.addEventListener('scroll', function() {
    const navbar = document.getElementById('navbar');
    if (window.scrollY > 50) {
      navbar.classList.add('navbar-scrolled');
    } else {
      navbar.classList.remove('navbar-scrolled');
    }
  });
  
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  
  mobileMenuBtn.addEventListener('click', function() {
    mobileMenu.classList.toggle('open');
    menuIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });
</script>

</body>
</html>
